# Server Environment Variables
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=5000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rmail
DB_USER=postgres
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=24h

# Default Admin (created on first db:init)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# IMAP / SMTP defaults (users can override per-account)
DEFAULT_IMAP_HOST=imap.example.com
DEFAULT_IMAP_PORT=993
DEFAULT_SMTP_HOST=smtp.example.com
DEFAULT_SMTP_PORT=465
